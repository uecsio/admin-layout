{
  "name": "@uecsio/admin-layout",
  "version": "0.1.0",
  "description": "UECS.IO admin layout components — configurable header, collapsible sidebar, and content area",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uecsio/admin-layout.git"
  },
  "homepage": "https://github.com/uecsio/admin-layout#readme",
  "bugs": {
    "url": "https://github.com/uecsio/admin-layout/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "admin",
    "layout",
    "sidebar",
    "dashboard",
    "tailwindcss",
    "component-library"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.15.0",
    "jsdom": "^20.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.0"
  }
}